# ─────────────────────────────────────────────────────────────────────────────
# Kanban Tools — environment configuration
# Copy to `.env.local` for local dev, or pass as env vars in Docker/production.
# All values are optional; sensible defaults are applied in src/lib/config.ts.
# ─────────────────────────────────────────────────────────────────────────────

# Where per-job temp files live. Each job gets its own subdirectory: <DIR>/<jobId>/
# Defaults to the OS temp dir + /convert-jobs if unset.
CONVERT_JOBS_DIR=/tmp/convert-jobs

# Maximum accepted upload size, in megabytes (per request).
MAX_FILE_SIZE_MB=512

# How long (in minutes) a completed/failed job is kept before the cleanup worker
# deletes its files. Lower this in shared/production environments.
JOB_TTL_MINUTES=30

# How often (in minutes) the background cleanup sweep runs.
CLEANUP_INTERVAL_MINUTES=5

# ── ZIP extraction safety limits (zip-bomb protection) ──
# Max total uncompressed bytes allowed out of a single archive.
ZIP_MAX_TOTAL_BYTES=1073741824
# Max number of entries (files) allowed in a single archive.
ZIP_MAX_ENTRIES=10000
# Max allowed compression ratio (uncompressed / compressed) before we treat it
# as a zip bomb and abort.
ZIP_MAX_COMPRESSION_RATIO=120

# ── Rate limiting (in-memory token bucket; swap for Redis in production) ──
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=40

# ── Link downloader ──
# Master switch for the public link downloader feature.
ENABLE_LINK_DOWNLOADER=true
# Path to the yt-dlp binary (used only for legally supported public media pages).
# Leave as "yt-dlp" to use whatever is on PATH. If yt-dlp is not installed, the
# downloader still handles direct file URLs and politely errors on media pages.
YTDLP_PATH=yt-dlp
# Max bytes the server will fetch when downloading a direct file URL.
LINK_MAX_DOWNLOAD_BYTES=1073741824

# ── External tool paths (override if not on PATH) ──
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
# Poppler utilities for PDF rasterization / SVG.
PDFTOPPM_PATH=pdftoppm
PDFTOCAIRO_PATH=pdftocairo
# Ghostscript for PDF compression (gs on Linux/mac, gswin64c on Windows).
GHOSTSCRIPT_PATH=gs

# ── Production storage placeholder (not used by the MVP) ──
# STORAGE_PROVIDER=local            # local | s3 | gcs | r2
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
